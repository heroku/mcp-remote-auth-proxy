{
  "name": "mcp-remote-auth-proxy",
  "version": "1.3.0",
  "description": "OIDC OAuth provider for remote MCP servers",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "test": "DOTENV_CONFIG_PATH=.env-test c8 mocha -r dotenv/config",
    "start": "node index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier . --write --config ./.prettier.mjs",
    "format": "pnpm run prettier && pnpm run lint:fix",
    "pretest": "pnpm run lint",
    "check": "pnpm run format && pnpm test",
    "ci": "pnpm run lint && pnpm test"
  },
  "license": "ISC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@heroku/oauth-provider-adapters-for-mcp": "^1.0.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-express": "^0.63.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/instrumentation-net": "^0.59.0",
    "@opentelemetry/instrumentation-undici": "^0.25.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "desm": "^1.3.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "lodash": "^4.18.1",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.11",
    "oidc-provider": "^9.6.1",
    "openid-client": "^6.8.4",
    "patch-package": "^8.0.1",
    "rate-limit-redis": "^4.3.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.5.0",
    "esmock": "^2.7.6",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "sinon": "^22.0.0"
  }
}
